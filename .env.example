# MikroControl Environment Variables
# Copy to .env and customize

# Database (PostgreSQL). Use a unique, randomly generated password.
DB_PASSWORD=replace-with-a-random-database-password
DATABASE_URL=postgresql://mikrocontrol:replace-with-a-random-database-password@localhost:5432/mikrocontrol

# Redis. Required for Docker deployments; use a separate random password.
REDIS_PASSWORD=replace-with-a-random-redis-password
REDIS_URL=redis://:${REDIS_PASSWORD}@localhost:6379/0

# JWT
SECRET_KEY=replace-with-a-random-secret-at-least-32-characters
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
DEBUG=false
# Same-origin deployments need no CORS origins. Add only approved origins, comma-separated.
CORS_ORIGINS=

# Telegram Alerts (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Email Alerts (optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=MikroControl <alerts@mikrocontrol.local>

# WireGuard (for remote access to routers)
WIREGUARD_INTERFACE=wg0
WIREGUARD_NETWORK=10.10.0.0/24

# RouterOS API
ROUTEROS_DEFAULT_USERNAME=admin
ROUTEROS_API_PORT=8728
ROUTEROS_API_SSL_PORT=8729
# Keep certificate verification enabled. Set false only as a temporary,
# documented exception for legacy RouterOS devices with self-signed TLS.
ROUTEROS_TLS_VERIFY=true
