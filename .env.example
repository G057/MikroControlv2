# MikroControl Environment Variables
# Copy to .env and customize

# Database (PostgreSQL)
DATABASE_URL=postgresql://mikrocontrol:mikrocontrol_secret_2026@localhost:5432/mikrocontrol
DB_PASSWORD=mikrocontrol_secret_2026

# JWT
SECRET_KEY=change-this-to-a-random-secret-key-at-least-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
DEBUG=false

# Telegram Alerts (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Email Alerts (optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=MikroControl <alerts@mikrocontrol.local>

# WireGuard (for remote access to routers)
WIREGUARD_INTERFACE=wg0
WIREGUARD_NETWORK=10.10.0.0/24

# RouterOS API
ROUTEROS_DEFAULT_USERNAME=admin
ROUTEROS_API_PORT=8728
ROUTEROS_API_SSL_PORT=8729
